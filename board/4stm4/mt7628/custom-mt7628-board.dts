// SPDX-License-Identifier: GPL-2.0-or-later
/*
 * SKELETON device tree for a custom MediaTek MT7628AN board.
 *
 *   SoC:   MT7628AN (MIPS 24KEc, little-endian)
 *   RAM:   16-bit DDR2, 128 MB   (DDR init lives in U-Boot / MediaTek BSP —
 *                                 OUT OF IMAGE SCOPE, see STEP 3)
 *   Flash: 16 MB SPI-NOR
 *   WiFi:  built-in 2.4 GHz 802.11n (mt7603, calibration from "factory" MTD)
 *
 * This is a SKELETON. Before a real build, fill in the items marked  TODO:
 *   - reset button GPIO pin        (STEP 4)
 *   - status LED GPIO pin          (STEP 4)
 *   - validate ethernet/switch port wiring against the schematic
 *
 * Flash partition offsets MUST stay in sync with src/flash_layout.py
 * (MT7628_16M_LAYOUT). Change offsets in ONE place — the layout module —
 * and mirror them here.
 *
 * Build note (path B / Buildroot + mainline): mainline has no OpenWrt
 * mtdsplit auto-split of a single "firmware" partition, so the firmware
 * region (0x050000..end) is split into EXPLICIT "kernel" + "rootfs"
 * partitions below.
 */

/dts-v1/;

#include "mt7628a.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	compatible = "custom,mt7628-board", "ralink,mt7628an-soc";
	model = "Custom MT7628 Board (SKELETON)";

	chosen {
		/* rootfs partition is resolved from the "rootfs" MTD partition
		 * (see &spi0 flash below). U-Boot passes the kernel; root= is
		 * pinned to the rootfs mtdblock. */
		bootargs = "console=ttyS0,115200 rootfstype=squashfs,jffs2";
	};

	aliases {
		led-boot = &led_status;
		led-running = &led_status;
	};

	/* ---- GPIO placeholders — STEP 4 (edit one line per pin) ---- */
	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			/* TODO: set real reset-button pin from EasyEDA schematic */
			gpios = <&gpio 0 GPIO_ACTIVE_LOW>;   /* TODO pin */
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_status: status {
			label = "status";
			/* TODO: set real status-LED pin from EasyEDA schematic */
			gpios = <&gpio 0 GPIO_ACTIVE_LOW>;   /* TODO pin */
		};
	};
};

/* ---------------- SPI-NOR 16 MB — STEP 1 layout ----------------
 * Offsets are the ramips MT7628 16M convention. Keep in sync with
 * src/flash_layout.py:MT7628_16M_LAYOUT.
 */
&spi0 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <40000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x000000 0x030000>;      /* 192k */
				read-only;
			};

			partition@30000 {
				label = "u-boot-env";
				reg = <0x030000 0x010000>;      /* 64k */
				read-only;
			};

			/* ART / EEPROM — per-device (MAC + RF calibration).
			 * NEVER written by the image assembler (STEP 2). */
			factory: partition@40000 {
				label = "factory";
				reg = <0x040000 0x010000>;      /* 64k */
				read-only;

				nvmem-layout {
					compatible = "fixed-layout";
					#address-cells = <1>;
					#size-cells = <1>;

					eeprom_factory_0: eeprom@0 {
						reg = <0x0 0x400>;
					};

					macaddr_factory_4: macaddr@4 {
						reg = <0x4 0x6>;
					};
				};
			};

			/* firmware region (0x050000..end, ~16064k) split EXPLICITLY
			 * into kernel + rootfs because mainline has no mtdsplit.
			 * kernel size is a PARAMETER (flash_layout.py: kernel size).
			 * rootfs grows to end of flash. */
			partition@50000 {
				label = "kernel";
				reg = <0x050000 0x200000>;      /* 2M cap — TODO size to real uImage */
			};

			partition@250000 {
				label = "rootfs";
				reg = <0x250000 0xdb0000>;      /* to end of 16M flash */
			};
		};
	};
};

/* ---------------- built-in 2.4 GHz WiFi (mt7603) ----------------
 * Calibration EEPROM read from the "factory" MTD partition @ 0x0.
 * Using the widely-compatible mediatek,mtd-eeprom form; the nvmem-cells
 * form (nvmem-cells = <&eeprom_factory_0>) is the newer alternative.
 */
&wmac {
	status = "okay";
	mediatek,mtd-eeprom = <&factory 0x0000>;
};

/* ---------------- ethernet / built-in switch ----------------
 * mt7628a.dtsi provides &ethernet and the built-in switch. Enable and
 * validate port wiring against the schematic (TODO).
 */
&ethernet {
	status = "okay";
	/* TODO: confirm LAN/WAN port split + phy-mode against schematic */
};
